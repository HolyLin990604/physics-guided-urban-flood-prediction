{
  "dataset": {
    "dataset_config_path": "configs/urbanflood24_lite_adapter.json",
    "train_split": "train",
    "val_fraction": 0.25
  },
  "model": {
    "flood_channels": 1,
    "static_channels": 3,
    "rainfall_channels": 1,
    "out_channels": 1,
    "base_channels": 16,
    "encoder_levels": 3,
    "temporal_hidden_channels": 128,
    "temporal_layers": 4,
    "temporal_kernel_size": 3,
    "dropout": 0.1,
    "skip_fusion_mode": "learned_weighted"
  },
  "optimization": {
    "epochs": 20,
    "batch_size": 2,
    "eval_batch_size": 2,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "loss": "smooth_l1",
    "grad_clip_norm": 1.0
  },
  "metrics": {
    "wet_threshold": 0.05
  },
  "runtime": {
    "seed": 123,
    "device": "cuda",
    "num_workers": 0,
    "use_amp": true
  },
  "output": {
    "root": "runs/stage2b_phase1_seed123",
    "selection_metric": "rmse",
    "max_visualization_batches": 2,
    "timeseries": {
      "mode": "pixels",
      "batch_index": 0,
      "pixel_coords": [[48, 48], [64, 64], [80, 80]]
    }
  },
  "physics_losses": {
    "non_negativity": {
      "enabled": true,
      "weight": 0.1
    },
    "wet_dry_consistency": {
      "enabled": true,
      "weight": 0.05,
      "threshold": 0.05,
      "temperature": 0.02
    },
    "rainfall_depth_consistency": {
      "enabled": false,
      "weight": 0.0,
      "eps": 1e-06
    },
    "topography_regularization": {
      "enabled": false,
      "weight": 0.0,
      "dem_channel": 0,
      "eps": 1e-06
    },
    "continuity_inspired": {
      "enabled": false,
      "weight": 0.0,
      "eps": 1e-06
    }
  }
}
