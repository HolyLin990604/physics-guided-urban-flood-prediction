{
  "dataset": {
    "dataset_config_path": "configs/urbanflood24_lite_adapter.json",
    "train_split": "train",
    "val_fraction": 0.25
  },
  "model": {
    "flood_channels": 1,
    "static_channels": 3,
    "rainfall_channels": 1,
    "out_channels": 1,
    "base_channels": 16,
    "encoder_levels": 3,
    "temporal_hidden_channels": 128,
    "temporal_layers": 4,
    "temporal_kernel_size": 3,
    "dropout": 0.1,
    "skip_fusion_mode": "learned_weighted",
    "rainfall_conditioning": {
      "enabled": true,
      "mode": "temporal_gate_residual_response_split_protected",
      "hidden_channels": 16,
      "residual_alpha": 0.10,
      "conditioned_fraction": 0.25,
      "active_fraction_within_response": 0.25,
      "adaptive_alpha_enabled": true,
      "adaptive_alpha_range": 0.25
    }
  },
  "optimization": {
    "epochs": 40,
    "batch_size": 2,
    "eval_batch_size": 2,
    "lr": 0.0003,
    "weight_decay": 0.0001,
    "loss": "smooth_l1",
    "grad_clip_norm": 1.0
  },
  "metrics": {
    "wet_threshold": 0.05
  },
  "runtime": {
    "seed": 202,
    "device": "cuda",
    "num_workers": 0,
    "use_amp": true
  },
  "output": {
    "root": "runs/phase6_pilot_a_temporal_gate_residual_response_split_protected_h16_a010_f025_af025_adapt025_40e_seed202",
    "selection_metric": "rmse",
    "max_visualization_batches": 2,
    "timeseries": {
      "mode": "region_average",
      "batch_index": 0,
      "row_range": [40, 88],
      "col_range": [40, 88]
    }
  },
  "physics_losses": {
    "non_negativity": {
      "enabled": true,
      "weight": 0.1
    },
    "wet_dry_consistency": {
      "enabled": true,
      "weight": 0.05,
      "threshold": 0.05,
      "temperature": 0.02
    },
    "rainfall_depth_consistency": {
      "enabled": true,
      "weight": 0.05,
      "eps": 1e-06,
      "normalization": "cumulative_l1",
      "use_cumulative": true,
      "smooth_positive_beta": 8.0,
      "detach_scale": false
    },
    "topography_regularization": {
      "enabled": false,
      "weight": 0.0,
      "dem_channel": 0,
      "eps": 1e-06
    },
    "continuity_inspired": {
      "enabled": false,
      "weight": 0.0,
      "eps": 1e-06
    }
  }
}
